# ============================================================
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local — ele já está no .gitignore
# ============================================================

# Supabase — usado pelas API routes (server-side apenas)
# Encontre em: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt>

# Espião NFe — tokens de acesso à API externa
ESP_CLOUD_TOKEN=<token>
USER_TOKEN=<token>
